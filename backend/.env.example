# ============================================================
# AhoyVPN Backend — Environment Variables
# Copy this to .env and fill in all values before starting
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_BASE_URL=https://ahoyvpn.net
FRONTEND_URL=https://ahoyvpn.net

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://ahoyvpn:ahoyvpn_secure_password@localhost:5432/ahoyvpn
DATABASE_ADMIN_URL=postgresql://ahoyvpn:ahoyvpn_secure_password@localhost:5432/ahoyvpn
DATABASE_AFFILIATE_URL=postgresql://ahoyvpn:ahoyvpn_secure_password@localhost:5432/ahoyvpn
DATABASE_SSL=false

# ── JWT / Auth ─────────────────────────────────────────────
JWT_SECRET=                    # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=          # Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Security ────────────────────────────────────────────────
CORS_ORIGIN=https://ahoyvpn.net
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── SMTP (Email) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM_SUPPORT=William@ahoyvpn.com
EMAIL_FROM_TRANSACTIONAL=noreply@ahoyvpn.net

# ── Plisio (Crypto Payments) ────────────────────────────────
PLISIO_API_KEY=t_NLT0XU0KP24rO9x0g94-HpZGGrItfn4KwRl3tCqSjGwPauCMCxymEJcZH5HKF6

# ── Authorize.net (Card Payments — Accept Hosted) ───────────
AUTHORIZE_NET_API_LOGIN_ID=    # From Authorize.net merchant dashboard
AUTHORIZE_NET_TRANSACTION_KEY= # From Authorize.net merchant dashboard
AUTHORIZE_NET_API_URL=https://api.authorize.net/xml/v1/request.api
AUTHORIZE_SIGNATURE_KEY=DFAA698189024C5AF287BA870D9CC31D2FA63916AEDDCED6C5A39154D79BA599D42847E948A903A89C4F0EE8ECB8ED1057B37C5635A7F06FE076EEDFA2AEECA9
DEBUG_AUTHORIZE_NET=false

# ── PaymentsCloud (Legacy/Alternate Card Processor) ───────
# ⚠️ CHANGE THIS — placeholder value is insecure
PAYCLOUD_SECRET=your_real_paymentscloud_webhook_secret

# ── VPN Resellers (White-label VPN Account Provisioning) ────
VPN_RESELLERS_API_TOKEN=       # From vpnresellers.com dashboard
VPN_RESELLERS_PLAN_MONTHLY_ID=
VPN_RESELLERS_PLAN_QUARTERLY_ID=
VPN_RESELLERS_PLAN_SEMIANNUAL_ID=
VPN_RESELLERS_PLAN_ANNUAL_ID=

# ── PureWL (Alternate VPN Provisioning) ─────────────────────
PUREWL_BASE_URL=
PUREWL_RESELLER_ID=
PUREWL_SECRET_KEY=

# ── Ziptax (Sales Tax — toggleable) ─────────────────────────
# Enable/disable via ZIPTAX_ENABLED=true/false
# State-level config (no code changes needed when toggling states)
ZIPTAX_API_KEY=
# ZIPTAX_ENABLED=true
# ZIPTAX_STATES=NY,NJ,CA

# ── Affiliate ───────────────────────────────────────────────
AFFILIATE_COMMISSION_RATE=0.25
AFFILIATE_MINIMUM_PER_USER=0.75
OPERATING_COST_PER_USER=1.20
FIXED_MONTHLY_COST=6.00
MIN_PAYOUT_CENTS=1000

# ── Account Generation ──────────────────────────────────────
ACCOUNT_NUMBER_LENGTH=8
PASSWORD_LENGTH=14
RECOVERY_KIT_LENGTH=32

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── Feature Toggles ─────────────────────────────────────────
# Set to 'true' to disable (site still works, these are polish features)
DISABLE_CLEANUP=false
DISABLE_PLISIO_POLLING=false
